# WMS 仓储管理系统 - 环境变量配置示例
# 复制此文件为 .env 并修改为实际值

# ==================== 应用配置 ====================
# 应用端口
APP_PORT=8080

# ==================== MySQL 数据库配置 ====================
# 数据库地址
DB_HOST=localhost

# 数据库端口
DB_PORT=3306

# 数据库名称
DB_NAME=wms

# 数据库用户名
DB_USERNAME=root

# 数据库密码（请修改为强密码）
DB_PASSWORD=your_password_here

# ==================== Redis 配置 ====================
# Redis 地址
REDIS_HOST=localhost

# Redis 端口
REDIS_PORT=6379

# Redis 密码（如有设置）
REDIS_PASSWORD=

# ==================== Elasticsearch 配置 ====================
# Elasticsearch 地址
ES_HOST=localhost

# Elasticsearch 端口
ES_PORT=9200

# ==================== DeepSeek AI 配置 ====================
# DeepSeek API Key（从 https://platform.deepseek.com 获取）
DEEPSEEK_API_KEY=your_api_key_here
